{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "MdConverter default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-execute",
    "shell:allow-open",
    "dialog:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir"
  ]
}
